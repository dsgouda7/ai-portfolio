#!/usr/bin/env bash
# pre-commit — scan staged changes for common secret patterns.
#
# Install:
#   bash scripts/install-hooks.sh        (macOS / Linux)
#   .\scripts\install-hooks.ps1          (Windows, run from repo root)
#
# Bypass (false positive confirmed): git commit --no-verify

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Secret patterns (PCRE — git grep -P)
# ---------------------------------------------------------------------------
declare -a PATTERNS=(
  # Private keys
  '-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY'
  # AWS access key IDs
  'AKIA[0-9A-Z]{16}'
  # AWS secret access key assignment
  '(aws_secret_access_key|AWS_SECRET_ACCESS_KEY)\s*[=:]\s*[A-Za-z0-9/+=]{40}'
  # GitHub tokens (classic PAT, fine-grained PAT, app tokens)
  'gh[pousr]_[A-Za-z0-9_]{36,}'
  'github_pat_[A-Za-z0-9_]{82}'
  # OpenAI / Anthropic / generic sk- keys
  'sk-[A-Za-z0-9]{20,}'
  # Azure storage / SAS keys (base64, 88 chars)
  'AccountKey=[A-Za-z0-9+/]{88}=='
  # Generic high-confidence assignments (password/api_key/secret = "value")
  '(password|passwd|api[_\-]?key|api[_\-]?secret|access[_\-]?token|auth[_\-]?token|client[_\-]?secret)\s*[:=]\s*["\x27][^\s"'\''\x27]{8,}'
  # Database connection strings with embedded credentials
  '(mongodb|postgres|postgresql|mysql|redis|amqp|amqps)://[^@\s]+:[^@\s]+@'
  # JWT tokens (three base64url segments)
  'eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}'
  # Google API keys
  'AIza[0-9A-Za-z_\-]{35}'
  # Slack tokens
  'xox[baprs]-[A-Za-z0-9\-]+'
)

# ---------------------------------------------------------------------------
# Collect staged diff (added/modified files only, no deletions)
# ---------------------------------------------------------------------------
DIFF=$(git diff --cached --unified=0 --diff-filter=ACM) || true

if [ -z "$DIFF" ]; then
  exit 0
fi

# Only inspect added lines (lines starting with +, skipping +++ headers)
ADDED=$(printf '%s' "$DIFF" | grep -P '^\+' | grep -vP '^\+\+\+' || true)

if [ -z "$ADDED" ]; then
  exit 0
fi

FOUND=0
for pattern in "${PATTERNS[@]}"; do
  matches=$(printf '%s' "$ADDED" | grep -P "$pattern" || true)
  if [ -n "$matches" ]; then
    printf "${RED}[secrets-check] Possible secret detected — pattern:${NC} %s\n" "$pattern"
    printf "${YELLOW}Matched lines:${NC}\n"
    printf '%s' "$matches" | head -5
    printf '\n\n'
    FOUND=1
  fi
done

if [ "$FOUND" -eq 1 ]; then
  printf "${RED}Commit rejected.${NC} Remove secrets before committing.\n"
  printf "${CYAN}Tip:${NC} Move secrets to a .env file, add it to .gitignore, and use os.environ in code.\n"
  printf "${CYAN}Bypass (false positive only):${NC} git commit --no-verify\n"
  exit 1
fi

exit 0
