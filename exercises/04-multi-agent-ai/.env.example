# Multi-Agent System Environment Variables

# OpenAI API Configuration (optional - for production LLM integration)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_org_id_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Flask API Configuration
FLASK_ENV=production
FLASK_DEBUG=False
API_HOST=0.0.0.0
API_PORT=5000

# Monitoring
PROMETHEUS_PORT=9090
METRICS_PREFIX=multiagent

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/multiagent.log

# Agent Configuration
MAX_CONCURRENT_AGENTS=4
TASK_TIMEOUT=300
MAX_RETRIES=3

# LLM Configuration
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30
